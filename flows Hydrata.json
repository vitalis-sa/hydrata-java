    {
        "id": "5d9bc37df04ee2b9",
        "type": "function",
        "z": "98f7df43ec05c43d",
        "name": "Formata Bomba",
        "func": "if (msg.payload.bomba_ativa === true || msg.payload.bomba_ativa === \"true\") {\n    msg.payload = \"LIGADA (Irrigando)\";\n    msg.color = \"blue\";\n} else {\n    msg.payload = \"DESLIGADA\";\n    msg.color = \"grey\";\n}\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 340,
        "wires": [
