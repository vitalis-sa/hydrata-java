            ]
        ]
    },
    {
        "id": "b78fd4e0ca092edb",
        "type": "function",
        "z": "98f7df43ec05c43d",
        "name": "Formata Alerta",
        "func": "if (msg.payload.alerta_critico === true || msg.payload.alerta_critico === \"true\") {\n    msg.payload = \"⚠️ CALOR TÉRMICO CRÍTICO (>=38°C)\";\n    msg.color = \"red\";\n} else {\n    msg.payload = \"SEGURO\";\n    msg.color = \"green\";\n}\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
